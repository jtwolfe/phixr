# Phixr Environment Configuration
# Copy this to .env.local and fill in your values

# GitLab Configuration
GITLAB_URL=http://192.168.1.145:8080
GITLAB_BOT_TOKEN=your-bot-personal-access-token-here
GITLAB_ROOT_TOKEN=your-root-personal-access-token-here
GITLAB_ROOT_PASSWORD=your-root-password-here

# Bot Configuration
BOT_USERNAME=phixr-bot
BOT_EMAIL=phixr-bot@localhost

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
PHIXR_API_URL=http://localhost:8000

# Webhook Configuration
WEBHOOK_SECRET=phixr-webhook-secret
WEBHOOK_URL=http://localhost:8000/webhooks/gitlab

# OpenCode Configuration
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key-here

# Sandbox Configuration
PHIXR_SANDBOX_DOCKER_HOST=unix:///run/user/1000/podman/podman.sock

# Database Configuration
POSTGRES_URL=postgresql://phixr:phixr@localhost:5432/phixr

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
