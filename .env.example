# Phixr Environment Configuration
# Copy this to .env.local and fill in your values:
#   cp .env.example .env.local

# ==============================================================================
# GitLab Configuration (required)
# ==============================================================================

GITLAB_URL=http://your-gitlab-instance:8080
GITLAB_BOT_TOKEN=glpat-your-bot-token-here

# Root token — only needed if you want automatic bot user creation
# or PAT rotation via the access management service. Optional.
# GITLAB_ROOT_TOKEN=glpat-your-root-token-here

# Bot identity
BOT_USERNAME=phixr
BOT_EMAIL=phixr@localhost

# ==============================================================================
# Webhook Configuration (required)
# ==============================================================================

# Secret shared between Phixr and GitLab for webhook validation
WEBHOOK_SECRET=your-webhook-secret-here

# Webhook callback URL — set to Phixr's public address
WEBHOOK_URL=http://localhost:8000/webhooks/gitlab

# ==============================================================================
# Server Configuration
# ==============================================================================

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Public-facing Phixr URL (used in GitLab comments for links)
PHIXR_API_URL=http://localhost:8000

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ==============================================================================
# Redis (optional — falls back to in-memory if unavailable)
# ==============================================================================

REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# OpenCode / AI Provider Configuration
# All sandbox settings use the PHIXR_SANDBOX_ prefix
# ==============================================================================

# OpenCode server (internal API URL)
PHIXR_SANDBOX_OPENCODE_SERVER_URL=http://localhost:4096

# Public URL for session links in GitLab comments
# Set this in production when the server URL is a Docker-internal hostname
PHIXR_SANDBOX_OPENCODE_PUBLIC_URL=http://localhost:4096

# Git provider token for cloning private repos inside sessions
# Typically the same as GITLAB_BOT_TOKEN
PHIXR_SANDBOX_GIT_PROVIDER_TOKEN=glpat-your-bot-token-here

# ------------------------------------------------------------------------------
# AI Provider — choose ONE provider and configure it below
# Supported: "ollama" (default), "zen", "openai"
# ------------------------------------------------------------------------------

PHIXR_SANDBOX_PROVIDER=ollama
PHIXR_SANDBOX_MODEL=qwen2.5-coder

# --- Ollama (local, no API key needed) ---
# Install: ollama pull qwen2.5-coder
# Larger models: qwen3-coder, qwen3-coder-next
PHIXR_SANDBOX_PROVIDER_BASE_URL=http://localhost:11434

# --- OpenCode Zen (cloud) ---
# PHIXR_SANDBOX_PROVIDER=zen
# PHIXR_SANDBOX_MODEL=big-pickle
# PHIXR_SANDBOX_PROVIDER_API_KEY=sk-your-zen-api-key

# --- OpenAI-compatible (cloud or local) ---
# PHIXR_SANDBOX_PROVIDER=openai
# PHIXR_SANDBOX_MODEL=gpt-4o
# PHIXR_SANDBOX_PROVIDER_API_KEY=sk-your-openai-key
# PHIXR_SANDBOX_PROVIDER_BASE_URL=https://api.openai.com/v1
