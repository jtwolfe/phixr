# Phixr Environment Configuration
# Copy this to .env.local and fill in your values

# GitLab Configuration
GITLAB_URL=http://localhost:8080
GITLAB_BOT_TOKEN=your-bot-personal-access-token-here
GITLAB_ROOT_PASSWORD=your-root-password-here

# Bot Configuration
BOT_USERNAME=phixr-bot
BOT_EMAIL=phixr-bot@localhost

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# Webhook Configuration
WEBHOOK_SECRET=phixr-webhook-secret
WEBHOOK_URL=http://localhost:8000/webhooks/gitlab

# Database Configuration
POSTGRES_URL=postgresql://phixr:phixr@localhost:5432/phixr

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
