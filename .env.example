# Phixr Environment Configuration
# Copy this to .env.local and fill in your values

# GitLab Configuration
GITLAB_URL=http://your-gitlab-instance:8080
GITLAB_BOT_TOKEN=your-bot-personal-access-token-here
GITLAB_ROOT_TOKEN=your-root-personal-access-token-here

# Bot Configuration
BOT_USERNAME=phixr
BOT_EMAIL=phixr@localhost

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PHIXR_API_URL=http://localhost:8000

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_URL=http://localhost:8000/webhooks/gitlab

# Redis Configuration (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# ==============================================================================
# OpenCode / AI Provider Configuration
# All sandbox settings use the PHIXR_SANDBOX_ prefix
# ==============================================================================

# OpenCode server (internal API URL)
PHIXR_SANDBOX_OPENCODE_SERVER_URL=http://localhost:4096
# Public URL for session links in GitLab comments (set in production)
PHIXR_SANDBOX_OPENCODE_PUBLIC_URL=http://localhost:4096

# Git provider token (for cloning private repos)
PHIXR_SANDBOX_GIT_PROVIDER_TOKEN=your-git-token-here

# ------------------------------------------------------------------------------
# AI Provider — choose ONE provider and configure it
# Supported: "ollama", "zen", "openai"
# ------------------------------------------------------------------------------

PHIXR_SANDBOX_PROVIDER=ollama
PHIXR_SANDBOX_MODEL=qwen2.5-coder

# --- Ollama (local, no API key needed) ---
# Default. Just run: ollama pull qwen2.5-coder
# Other models: qwen3-coder (large), qwen3-coder-next (very large)
PHIXR_SANDBOX_PROVIDER_BASE_URL=http://localhost:11434

# --- OpenCode Zen (cloud) ---
# PHIXR_SANDBOX_PROVIDER=zen
# PHIXR_SANDBOX_MODEL=big-pickle
# PHIXR_SANDBOX_PROVIDER_API_KEY=sk-your-zen-api-key

# --- OpenAI-compatible (cloud or local) ---
# PHIXR_SANDBOX_PROVIDER=openai
# PHIXR_SANDBOX_MODEL=gpt-4o
# PHIXR_SANDBOX_PROVIDER_API_KEY=sk-your-openai-key
# PHIXR_SANDBOX_PROVIDER_BASE_URL=https://api.openai.com/v1
